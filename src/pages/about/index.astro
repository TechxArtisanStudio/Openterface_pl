---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { docsPath } from '../../config/site';
---

<BaseLayout
  title="O Openterface"
  description="Poznaj Openterface — open-source rozwiązania KVM-over-USB od TechxArtisan."
  ogImageAlt="Open-source rozwiązania Openterface KVM-over-USB od TechxArtisan"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">O Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface tworzy ultrakompaktowe open-source narzędzia KVM-over-USB dla specjalistów IT, deweloperów i makerów.
        Od crowdfundingu Mini-KVM po KVM-GO wielkości breloku i programowalną serię KeyMod — naszą misją jest uproszczenie zarządzania komputerami headless bez gabarytowego sprzętu i skomplikowanych sieci.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={docsPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Więcej o nas →
        </a>
        <a href={docsPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Zgodność →
        </a>
        <a href={docsPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Społeczność →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
